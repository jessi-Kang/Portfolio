rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Portfolio site collection — public read, authenticated write
    match /site/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
